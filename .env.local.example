# ── SUPABASE ────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server only, never expose

# ── STRIPE ──────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...     # from: stripe listen --print-secret

# Stripe Price IDs — create in Stripe dashboard → Products
STRIPE_PRICE_PRO=price_...          # $49/mo
STRIPE_PRICE_ELITE=price_...        # $149/mo

# ── APP ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.apex-hl.io  # your domain
NEXT_PUBLIC_LANDING_URL=https://apex-hl.io

# ── BOT API ─────────────────────────────────────────────────────
# Secret key the bot uses to POST trade data to your API
BOT_API_SECRET=generate-a-random-32-char-string-here
