# ── SUPABASE ────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server only, never expose

# ── STRIPE ──────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...     # from: stripe listen --print-secret

# Stripe Price IDs — create in Stripe dashboard → Products
STRIPE_PRICE_PRO=price_...          # $49/mo
STRIPE_PRICE_ELITE=price_...        # $149/mo

# ── APP ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.apexhl.trade

# ── ENCRYPTION ──────────────────────────────────────────────────
# Required for encrypting API keys before storing in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-string-here

# ── BOT API ─────────────────────────────────────────────────────
# Secret key the bot uses to POST trade data to your API
# Generate with: openssl rand -hex 16
BOT_API_SECRET=generate-a-random-32-char-string-here

# ── EMAIL (Resend) ─────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
FROM_EMAIL=APEX <noreply@apexhl.trade>

# ── AI CHAT (optional) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── PYTHON BOT ──────────────────────────────────────────────────
# These are used by apex_bot.py, not the Next.js app
# HL_WALLET_ADDRESS=0x...
# HL_API_SECRET=0x...
# APEX_USER_ID=your-supabase-user-uuid
# PAPER_TRADE=true
